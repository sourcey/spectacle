{
  "name": "sourcey",
  "version": "3.3.10",
  "description": "Open source documentation platform. API references, guides, static output.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "sourcey": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && cp -r src/themes dist/ && cp src/client/*.js dist/client/",
    "watch": "npm run build && tsc --watch --preserveWatchOutput",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ test/",
    "lint:fix": "eslint src/ test/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@preact/preset-vite": "^2.10.4",
    "@readme/openapi-parser": "^4.0.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "citty": "^0.1.6",
    "jiti": "^2.6.1",
    "js-yaml": "^4.1.0",
    "marked": "^15.0.0",
    "mcp-parser": "^0.2.0",
    "moxygen": "^2.1.1",
    "preact": "^10.28.4",
    "preact-render-to-string": "^6.6.6",
    "shiki": "^4.0.2",
    "swagger2openapi": "^7.0.8",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.19.15",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "openapi",
    "swagger",
    "api",
    "documentation",
    "static-site-generator",
    "docs",
    "markdown",
    "api-docs",
    "developer-documentation",
    "doxygen"
  ],
  "funding": {
    "url": "https://sourcey.com"
  },
  "author": "Kam Low <oss@0state.com> (https://sourcey.com)",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sourcey/sourcey.git"
  },
  "bugs": {
    "url": "https://github.com/sourcey/sourcey/issues"
  },
  "homepage": "https://sourcey.com"
}
