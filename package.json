{
  "name": "spectacle-docs",
  "version": "2.0.0",
  "description": "Generate beautiful static API documentation from OpenAPI/Swagger specifications",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "spectacle": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && cp -r src/themes dist/ && cp -r src/client dist/",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ test/",
    "lint:fix": "eslint src/ test/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@readme/openapi-parser": "^4.0.0",
    "citty": "^0.1.6",
    "js-yaml": "^4.1.0",
    "marked": "^15.0.0",
    "preact": "^10.28.4",
    "preact-render-to-string": "^6.6.6",
    "shiki": "^4.0.2",
    "swagger2openapi": "^7.0.8"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.19.15",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "openapi",
    "swagger",
    "api",
    "documentation",
    "static-site-generator",
    "docs"
  ],
  "author": "Kam Low <auscaster@gmail.com> (https://sourcey.com)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sourcey/spectacle.git"
  },
  "bugs": {
    "url": "https://github.com/sourcey/spectacle/issues"
  },
  "homepage": "https://github.com/sourcey/spectacle#readme"
}
